{
  "openapi": "3.0.4",
  "info": {
    "title": "SkyRouteAPI",
    "version": "1.0"
  },
  "paths": {
    "/api/Airports": {
      "get": {
        "tags": [
          "Airports"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Bookings": {
      "post": {
        "tags": [
          "Bookings"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BookingRequestDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/BookingRequestDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/BookingRequestDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Flights/search": {
      "post": {
        "tags": [
          "Flights"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FlightSearchRequestDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/FlightSearchRequestDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/FlightSearchRequestDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "BookingRequestDto": {
        "required": [
          "destination",
          "documentNumber",
          "emailAddress",
          "flightNumber",
          "fullName",
          "origin"
        ],
        "type": "object",
        "properties": {
          "flightNumber": {
            "minLength": 1,
            "type": "string"
          },
          "origin": {
            "minLength": 1,
            "type": "string"
          },
          "destination": {
            "minLength": 1,
            "type": "string"
          },
          "passengers": {
            "maximum": 9,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          },
          "fullName": {
            "minLength": 1,
            "type": "string"
          },
          "emailAddress": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "documentNumber": {
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "FlightSearchRequestDto": {
        "required": [
          "cabinClass",
          "departureDate",
          "destination",
          "origin"
        ],
        "type": "object",
        "properties": {
          "origin": {
            "minLength": 1,
            "pattern": "\\S+",
            "type": "string"
          },
          "destination": {
            "minLength": 1,
            "pattern": "\\S+",
            "type": "string"
          },
          "departureDate": {
            "type": "string",
            "format": "date-time"
          },
          "passengers": {
            "maximum": 9,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          },
          "cabinClass": {
            "minLength": 1,
            "pattern": "\\S+",
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "tags": [
    {
      "name": "Airports"
    },
    {
      "name": "Bookings"
    },
    {
      "name": "Flights"
    }
  ]
}